# Environment
ENVIRONMENT=development
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=herlin
DB_PASSWORD=herlin123
DB_NAME=herlin_db
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-change-in-production

# AI Providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-opus-20240229
